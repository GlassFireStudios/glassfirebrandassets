# ── GitHub (required to publish) ───────────────────────────────────────────
# Fine-grained PAT with "Contents: Read and write" on this repo only.
GITHUB_TOKEN=
GITHUB_REPO=GlassFireStudios/glassfirebrandassets
# Branch the manifest/assets are read from and the default publish base.
GITHUB_BASE_BRANCH=main

# ── Brandfetch (recommended logo search) ───────────────────────────────────
# Client ID powers brand search; API key unlocks full logo variants.
# https://developers.brandfetch.com/
BRANDFETCH_CLIENT_ID=
BRANDFETCH_API_KEY=

# ── Google Programmable Search (optional "whole web" image layer) ───────────
# https://programmablesearchengine.google.com/  +  Custom Search JSON API key
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# ── Image CDN (optional — defaults to free jsDelivr) ───────────────────────
# Serve embed images from your own domain via a Bunny pull zone instead of
# jsDelivr. Set up a Bunny Pull Zone with origin
#   https://cdn.jsdelivr.net/gh/GlassFireStudios/glassfirebrandassets@main/
# (or the raw.githubusercontent equivalent), map it to e.g. cdn.glassfire.co,
# then set the base below. Exports and saved live embeds will use it; leave
# empty to keep using jsDelivr. No trailing slash.
NEXT_PUBLIC_CDN_BASE=

# ── Testimonials (optional) ────────────────────────────────────────────────
# Your Google "write a review" link. When set, the thank-you screen after a
# client submits offers a one-tap "Post my review to Google" button (copies
# their text + opens this URL). Find it in Google Business Profile → Ask for
# reviews, e.g. https://g.page/r/XXXXXXXXXXXX/review
NEXT_PUBLIC_GOOGLE_REVIEW_URL=

# ── Access control (recommended in production) ─────────────────────────────
# If unset, the app is open (fine for local dev). Set this in Vercel.
# Used as the login until Google sign-in below is configured.
APP_PASSWORD=

# ── Google sign-in (Auth.js) — verified per-editor accounts ────────────────
# When AUTH_GOOGLE_ID is set, the whole tool switches from the shared password
# to "Sign in with Google", restricted to AUTH_ALLOWED_DOMAIN. Until then it
# stays on APP_PASSWORD, so nothing breaks before you configure this.
#   1. Google Cloud Console → Credentials → OAuth client ID (Web application).
#   2. Authorized redirect URI: https://<your-domain>/api/auth/callback/google
#   3. Set the three vars below (AUTH_SECRET: run `npx auth secret` or any long random string).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
AUTH_ALLOWED_DOMAIN=glassfire.co

# ── Machine tracker idle nudge (Vercel Cron + Slack) ───────────────────────
# An hourly cron (vercel.json) warns an editor in Slack after they've been
# signed onto a machine too long, then auto–signs them out after a grace period.
# SLACK_BOT_TOKEN: a Slack bot token with users:read.email + chat:write.
# CRON_SECRET: any long random string; Vercel sends it to the cron endpoint.
# Without Slack, idle sessions are still auto–signed out (just no DM).
SLACK_BOT_TOKEN=
CRON_SECRET=
MACHINE_IDLE_HOURS=8
MACHINE_IDLE_GRACE_MIN=30
